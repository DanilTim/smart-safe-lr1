<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#121212">

    <!-- Иконка сейфа -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒"
        android:textSize="72sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Умный сейф"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <!-- Сохранённая комбинация -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Комбинация:"
        android:textColor="#AAAAAA"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvSavedCombo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Не задана"
        android:textColor="#FFD700"
        android:textSize="28sp"
        android:layout_marginBottom="32dp"
        android:letterSpacing="0.1" />

    <!-- Разделитель -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="24dp" />

    <!-- Ввод пользователя -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ваш ввод:"
        android:textColor="#AAAAAA"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvInput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="#00E5FF"
        android:textSize="28sp"
        android:layout_marginBottom="24dp" />

    <!-- Статус -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Введите комбинацию наклонами"
        android:textColor="#CCCCCC"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <!-- Кнопки -->
    <Button
        android:id="@+id/btnReset"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Сбросить ввод"
        android:backgroundTint="#333333"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnSetup"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="⚙️  Задать комбинацию"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF" />

</LinearLayout>